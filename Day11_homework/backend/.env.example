# ─── Server ──────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ─── Logging ─────────────────────────────────────────────────────────────────
# Options: error | warn | info | http | debug
LOG_LEVEL=http

# ─── Database (Supabase PostgreSQL — Direct Connection) ──────────────────────
# Use the "Direct connection" string from Supabase → Project Settings → Database
# Format: postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT_REF.supabase.co:5432/postgres

# ─── CORS ────────────────────────────────────────────────────────────────────
# Use * for all origins, or comma-separated for production (e.g. https://myapp.com)
ALLOWED_ORIGINS=*
